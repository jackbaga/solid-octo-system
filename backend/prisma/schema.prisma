generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Volunteer {
  id           Int             @id @default(autoincrement())
  sheetId      Int
  sheet        VolunteerSheet  @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  name         String
  age          Int?
  phone        String
  account      String?
  password     String?
  status       VolunteerStatus @default(NOT_CALLED)
  teacher      Teacher?
  remark       String?
  appointments Appointment[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
  @@index([sheetId])
  @@index([phone])
  @@unique([sheetId, name, phone])
}

model VolunteerSheet {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  volunteers Volunteer[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Appointment {
  id          Int      @id @default(autoincrement())

  volunteerId Int?
  volunteer   Volunteer? @relation(fields: [volunteerId], references: [id])

  subjectName String @default("")
  date        String
  time        String

  projectType AppointmentProjectType
  projectName String?
  session     String?
  round       String?
  remark      String?
  status      AppointmentStatus @default(BOOKED)
  taskCompletion TaskCompletion?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([volunteerId])
}

model AppointmentTaskConfig {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  sessions  String[] @default([])
  rounds    Int[]    @default([])
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppointmentDay {
  id         Int      @id @default(autoincrement())
  date       String   @unique
  assistants String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TaskCompletion {
  id            Int         @id @default(autoincrement())
  appointmentId Int         @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  date          String
  completed     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([date])
}

model TaskCompletionRecord {
  id                    Int      @id @default(autoincrement())
  subjectName           String
  subjectCode           String   @default("")
  paymentStatus         String?
  cognitiveReportStatus String?
  remark                String?
  tasks                 Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([subjectName, subjectCode])
  @@index([subjectName])
}

enum VolunteerStatus {
  NOT_CALLED
  NO_ANSWER
  REJECTED
  AVAILABLE
  WECHAT_ADDED
  APPOINTED
}

enum Teacher {
  WANG_LE
  WEI_SHIYIN
}

enum AppointmentProjectType {
  MRI
  EEG
  COGNITION
  INTERVIEW
  PARENT_INTERVIEW
  FORMAL_TEST
  OTHER
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
}
